{
  "name": "s3-hls-transcoder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted HLS video transcoder for S3-compatible buckets",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "**/*.{ts,js,json,md,yaml,yml}": "prettier --write"
  }
}
