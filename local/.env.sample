# =============================================================================
# Bucket configuration. Two ways to provide it:
#
# (A) Single source/dest pair via SOURCE_* and DEST_* env vars (below).
#     Simplest. Use this for one-shot setups.
#
# (B) Multiple pairs via BUCKETS_CONFIG_FILE (path) or BUCKETS_CONFIG (JSON).
#     Each pair has its own source/dest, optionally with per-bucket or
#     per-pair credentials. See "Multi-pair config" section below.
#
# Priority: BUCKETS_CONFIG_FILE > BUCKETS_CONFIG > SOURCE_*/DEST_*.
# Source bucket and destination bucket must NOT overlap (same bucket+endpoint
# with one prefix being a prefix of the other) — startup will refuse.
# =============================================================================

# --- Single-pair config (option A) ------------------------------------------

# Source bucket (read-only — never modified or deleted from).
SOURCE_BUCKET=
SOURCE_ENDPOINT=
SOURCE_ACCESS_KEY_ID=
SOURCE_SECRET_ACCESS_KEY=
SOURCE_REGION=auto
# Optional: limit scan to a path prefix.
SOURCE_PREFIX=

# Destination bucket (HLS output, manifests, fingerprints).
DEST_BUCKET=
DEST_ENDPOINT=
DEST_ACCESS_KEY_ID=
DEST_SECRET_ACCESS_KEY=
DEST_REGION=auto

# --- Multi-pair config (option B) -------------------------------------------
#
# BUCKETS_CONFIG_FILE points at a JSON file like:
#   [
#     {
#       "source": { "bucket": "src1", "endpoint": "https://...", "prefix": "videos/" },
#       "dest":   { "bucket": "dst1", "endpoint": "https://..." },
#       "accessKeyId": "...",        // pair-level (used by both buckets unless overridden)
#       "secretAccessKey": "..."
#     },
#     {
#       "source": {
#         "bucket": "src2", "endpoint": "https://...",
#         "accessKeyId": "...",      // bucket-level (overrides pair + env)
#         "secretAccessKey": "..."
#       },
#       "dest":   { "bucket": "dst2", "endpoint": "https://..." }
#       // No pair-level credentials — dest falls back to DEST_ACCESS_KEY_ID/etc env vars.
#     }
#   ]
#
# Credential cascade for each bucket: bucket-level → pair-level → env-level
# (SOURCE_ACCESS_KEY_ID / DEST_ACCESS_KEY_ID).
#
# BUCKETS_CONFIG_FILE=/etc/transcoder/buckets.json
# BUCKETS_CONFIG=

# --- ABR ladder -------------------------------------------------------------
# JSON array of { name, width, height, videoBitrateKbps, audioBitrateKbps }.
# Default: 360p / 480p / 720p / 1080p H.264 + AAC.
# HLS_LADDER=

# --- Runtime budget ---------------------------------------------------------
# Defaults: aws=900, cloudflare=3600, local=3600.
# MAX_RUNTIME_SECONDS=
# Lock TTL = MAX_RUNTIME × LOCK_TTL_MULTIPLIER (default 1.5).
# Self-imposed per-invocation budget = MAX_RUNTIME × BUDGET_MULTIPLIER (default 0.75).
# LOCK_TTL_MULTIPLIER=1.5
# BUDGET_MULTIPLIER=0.75

# --- Perceptual dedup tuning ------------------------------------------------
# PERCEPTUAL_THRESHOLD=0.95
# PERCEPTUAL_DRY_RUN=false

# --- Misc -------------------------------------------------------------------
# MAX_CONCURRENCY=1
# LOG_LEVEL=info
