  },
  "devDependencies": {
    "@cloudflare/containers": "^0.3.3",
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
